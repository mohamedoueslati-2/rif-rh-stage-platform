# ============================================
# Serveur Spring Boot
# ============================================

# Port HTTP utilisé par l'API backend.
SERVER_PORT=8090

# Port HTTP exposé par le frontend Nginx.
FRONTEND_PORT=4200


# ============================================
# Authentification JWT
# ============================================

# Clé privée utilisée pour signer les JWT.
# Utiliser une valeur longue, aléatoire et différente dans chaque environnement.
JWT_SECRET=replace_with_a_long_random_secret_key

# Durée de validité du token en millisecondes (86400000 = 24 heures).
JWT_EXPIRATION_MS=86400000


# ============================================
# Base de données PostgreSQL
# ============================================

# URL JDBC de la base PostgreSQL.
DB_URL=jdbc:postgresql://localhost:5432/rif_rh_stage_db

# Nom et port exposé de la base utilisés par Docker Compose.
DB_NAME=rif_rh_stage_db
DB_PORT=5432

# Identifiants PostgreSQL locaux.
DB_USERNAME=postgres
DB_PASSWORD=change_me


# ============================================
# CORS et frontend
# ============================================

# Origines autorisées, séparées par des virgules et sans espace.
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:5173


# ============================================
# Compte RH initial
# ============================================

# Compte RH créé automatiquement au démarrage s'il n'existe pas encore.
SEED_RH_EMAIL=rh@example.com
SEED_RH_PASSWORD=ChangeMe@123456


# ============================================
# JPA et application
# ============================================

# Conserver "update" en développement pour ne pas supprimer les données.
# Ne pas utiliser "create-drop" avec des données importantes.
JPA_DDL_AUTO=update

# Affiche les requêtes SQL dans les logs (mettre false en production).
JPA_SHOW_SQL=true

# Fuseau horaire utilisé pour les dates de l'application.
APP_TIMEZONE=Africa/Tunis


# ============================================
# Notifications email SMTP
# ============================================

# Configuration SMTP Gmail. Un mot de passe d'application est recommandé.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password(16_characters)
